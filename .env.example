# =============================================================================
# Seismic Platform — Variables de entorno
# Copiar este archivo a .env y completar con valores reales
# NUNCA commitear el .env real
# =============================================================================

# --- MongoDB ---
MONGO_HOST=mongodb
MONGO_PORT=27017
MONGO_USER=seismic_user
MONGO_PASSWORD=change_me_mongo
MONGO_DB=seismic_db
MONGO_URI=mongodb://${MONGO_USER}:${MONGO_PASSWORD}@${MONGO_HOST}:${MONGO_PORT}/${MONGO_DB}?authSource=admin

# --- Redis ---
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_URL=redis://${REDIS_HOST}:${REDIS_PORT}/0

# --- API ---
API_HOST=0.0.0.0
API_PORT=8000
API_ENV=development

# --- JWT Auth ---
JWT_SECRET_KEY=change_me_super_secret_key_min_32_chars
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=15
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# --- Usuario seed (se crea al iniciar la API) ---
SEED_USERNAME=admin
SEED_PASSWORD=change_me_admin_password
SEED_EMAIL=admin@example.com

# --- Ingesta USGS ---
USGS_API_URL=https://earthquake.usgs.gov/earthquakes/feed/v1.0/summary/all_hour.geojson
INGESTION_INTERVAL_SECONDS=180

# --- Caché Redis TTL ---
METRICS_CACHE_TTL_SECONDS=60

# --- Airflow ---
AIRFLOW__CORE__EXECUTOR=SequentialExecutor
AIRFLOW__CORE__FERNET_KEY=change_me_fernet_key_base64_encoded
AIRFLOW__CORE__LOAD_EXAMPLES=False
AIRFLOW__DATABASE__SQL_ALCHEMY_CONN=sqlite:////opt/airflow/airflow.db
AIRFLOW__WEBSERVER__SECRET_KEY=change_me_airflow_secret
AIRFLOW_ADMIN_USERNAME=admin
AIRFLOW_ADMIN_PASSWORD=change_me_airflow_password
AIRFLOW_ADMIN_EMAIL=admin@example.com

# --- Prometheus ---
PROMETHEUS_PORT=9090

# --- Grafana ---
GRAFANA_PORT=3000
GF_SECURITY_ADMIN_USER=admin
GF_SECURITY_ADMIN_PASSWORD=change_me_grafana

# --- Frontend ---
FRONTEND_PORT=4200
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_WS_URL=ws://localhost:8000
