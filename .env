# =============================================================================
# Seismic Platform — Variables de entorno (desarrollo local)
# =============================================================================

# --- MongoDB ---
MONGO_HOST=mongodb
MONGO_PORT=27017
MONGO_USER=seismic_user
MONGO_PASSWORD=seismic_pass_local
MONGO_DB=seismic_db
MONGO_URI=mongodb://seismic_user:seismic_pass_local@mongodb:27017/seismic_db?authSource=admin

# --- Redis ---
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_URL=redis://redis:6379/0

# --- API ---
API_HOST=0.0.0.0
API_PORT=8000
API_ENV=development

# --- JWT Auth ---
JWT_SECRET_KEY=local_dev_secret_key_32chars_minimum_ok
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=15
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# --- Usuario seed ---
SEED_USERNAME=admin
SEED_PASSWORD=admin123
SEED_EMAIL=admin@example.com

# --- Ingesta USGS ---
USGS_API_URL=https://earthquake.usgs.gov/earthquakes/feed/v1.0/summary/all_hour.geojson
INGESTION_INTERVAL_SECONDS=180

# --- Caché Redis TTL ---
METRICS_CACHE_TTL_SECONDS=60

# --- Airflow ---
AIRFLOW__CORE__EXECUTOR=SequentialExecutor
AIRFLOW__CORE__FERNET_KEY=ZmDfcTF7_60GrrY167zsiPd67pEvs0aGOv2oasOM1Pg=
AIRFLOW__CORE__LOAD_EXAMPLES=False
AIRFLOW__DATABASE__SQL_ALCHEMY_CONN=sqlite:////opt/airflow/airflow.db
AIRFLOW__WEBSERVER__SECRET_KEY=airflow_local_webserver_secret_key
AIRFLOW_ADMIN_USERNAME=admin
AIRFLOW_ADMIN_PASSWORD=admin123
AIRFLOW_ADMIN_EMAIL=admin@example.com

# --- Prometheus ---
PROMETHEUS_PORT=9090

# --- Grafana ---
GRAFANA_PORT=3000
GF_SECURITY_ADMIN_USER=admin
GF_SECURITY_ADMIN_PASSWORD=admin123

# --- Frontend ---
FRONTEND_PORT=4200
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_WS_URL=ws://localhost:8000
